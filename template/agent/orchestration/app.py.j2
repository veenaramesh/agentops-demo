#####################
## Lakebase: async per-request agent (conversation checkpointing)
#####################

_max_iter = model_config.get("llm_max_iterations") or 10
{% if workflow_pattern == "single" %}
_outer_recursion_limit = _max_iter * 2 + 1
{% elif workflow_pattern == "supervisor_worker" %}
_outer_recursion_limit = _max_iter * {{ worker_llms | length }} * 2 + 1
{% else %}
_outer_recursion_limit = 50
{% endif %}

def _get_thread_id(request: ResponsesAgentRequest) -> str:
    """Priority: custom_inputs.conversation_id → new uuid7 per request."""
    custom_inputs = request.custom_inputs or {}
    if "conversation_id" in custom_inputs:
        return custom_inputs["conversation_id"]
    return str(uuid7())


@stream()
async def predict_stream(
    request: ResponsesAgentRequest,
) -> AsyncGenerator[ResponsesAgentStreamEvent, None]:
    cc_msgs = to_chat_completions_input([i.model_dump() for i in request.input])
    thread_id = _get_thread_id(request)
    seen_ids: set = set()
    first_message = True

    async with AsyncCheckpointSaver(instance_name="{{ lakebase_instance_name }}") as checkpointer:
        _compiled = workflow.compile(checkpointer=checkpointer)
        async for _, events in _compiled.astream(
            {"messages": cc_msgs},
            stream_mode=["updates"],
            config={
                "configurable": {"thread_id": thread_id},
                "recursion_limit": _outer_recursion_limit,
            },
        ):
            new_msgs = [
                msg
                for v in events.values()
                for msg in v.get("messages", [])
                if msg.id not in seen_ids
            ]
            if first_message:
                seen_ids.update(msg.id for msg in new_msgs[: len(cc_msgs)])
                new_msgs = new_msgs[len(cc_msgs):]
                first_message = False
            else:
                seen_ids.update(msg.id for msg in new_msgs)
{% if workflow_pattern == "supervisor_worker" %}
            node_name = next(iter(events.keys()), None)
            if node_name:
                routing_msg = AIMessage(content=f"<name>{node_name}</name>", id=str(uuid4()))
                for ev in output_to_responses_items_stream([routing_msg]):
                    yield ev
{% endif %}
            for ev in output_to_responses_items_stream(new_msgs):
                yield ev


@invoke()
async def predict(request: ResponsesAgentRequest) -> ResponsesAgentResponse:
    outputs = []
    async for event in predict_stream(request):
        if event.type == "response.output_item.done":
            outputs.append(event.item)
    return ResponsesAgentResponse(output=outputs, custom_outputs=request.custom_inputs)
{% endif %}

