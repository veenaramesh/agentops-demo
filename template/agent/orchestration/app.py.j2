# Routing schema — supervisor picks the next worker or signals FINISH
class RouteDecision(PydanticBaseModel):
    next: Literal[{% for w in worker_llms %}"{{ w.name }}", {% endfor %}"FINISH"]

# ── Worker sub-agents (each runs its own ReAct loop) ─────────────────────────
{% for worker in worker_llms %}
_{{ worker.name }}_agent = create_react_agent({{ worker.name }}_model, {{ worker.name }}_tools)

def {{ worker.name }}_node(state: AgentState, config: RunnableConfig):
    result = _{{ worker.name }}_agent.invoke({"messages": state["messages"]}, config)
    # Return only newly generated messages (create_react_agent includes the input)
    return {"messages": result["messages"][len(state["messages"]):]}
{% endfor %}
# ── Supervisor node ───────────────────────────────────────────────────────────
def supervisor_node(state: AgentState, config: RunnableConfig):
    worker_info = "\n".join([
{%- for w in worker_llms %}
        "- {{ w.name }}: handles {{ w.tools | map(attribute='name') | join(', ') or 'general tasks' }}{% if w.retrievers %}, retrieves from {{ w.retrievers | map(attribute='name') | join(', ') }}{% endif %}",
{%- endfor %}
    ])
    base_system = (
        "You are a supervisor managing these specialized workers:\n"
        f"{worker_info}\n"
        "Route the task to the right worker, or return FINISH when the task is complete."
    )
    sys_msg = (system_prompt + "\n\n" + base_system) if system_prompt else base_system
    msgs = [{"role": "system", "content": sys_msg}] + list(state["messages"])
    structured = supervisor_model.with_structured_output(RouteDecision)
    decision = structured.invoke(msgs)
    return {"next": decision.next}

# ── Graph ─────────────────────────────────────────────────────────────────────
workflow = StateGraph(AgentState)
workflow.add_node("supervisor", RunnableLambda(supervisor_node))
{% for worker in worker_llms %}
workflow.add_node("{{ worker.name }}", RunnableLambda({{ worker.name }}_node))
{% endfor %}
workflow.set_entry_point("supervisor")
workflow.add_conditional_edges(
    "supervisor",
    lambda state: state["next"],
    {
{%- for worker in worker_llms %}
        "{{ worker.name }}": "{{ worker.name }}",
{%- endfor %}
        "FINISH": END,
    },
)
{% for worker in worker_llms %}
workflow.add_edge("{{ worker.name }}", "supervisor")
{% endfor %}

