# BranchState: passed to each branch via Send (subset of AgentState)
class BranchState(TypedDict):
    messages: Sequence[BaseMessage]

# ── Branch nodes (run in parallel) ───────────────────────────────────────────
{% for branch in parallel_branches %}
_{{ branch.name }}_agent = create_react_agent({{ branch.name }}_model, {{ branch.name }}_tools)

def {{ branch.name }}_node(state: BranchState) -> dict:
    """Parallel branch {{ loop.index }}/{{ parallel_branches | length }}: {{ branch.name }}."""
    result = _{{ branch.name }}_agent.invoke(dict(state))
    last = result["messages"][-1]
    content = last.content if hasattr(last, "content") else str(last)
    return {"branch_results": [f"[{{ branch.name }}] {content}"]}
{% endfor %}

def fan_out(state: AgentState) -> list[Send]:
    """Dispatch to all branches in parallel."""
    return [
{%- for branch in parallel_branches %}
        Send("{{ branch.name }}", {"messages": state["messages"]}),
{%- endfor %}
    ]

def aggregator_node(state: AgentState, config: RunnableConfig):
    """Synthesize parallel branch results into a single final answer."""
    combined = "\n\n".join(state["branch_results"])
    msgs = list(state["messages"]) + [
        {
            "role": "user",
            "content": (
                "Multiple specialized agents have provided these results in parallel:\n\n"
                f"{combined}\n\n"
                "Synthesize them into a single, coherent final answer."
            ),
        }
    ]
    response = aggregator_model.invoke(msgs)
    return {"messages": [response]}

# ── Graph (fan-out → parallel branches → aggregator) ─────────────────────────
workflow = StateGraph(AgentState)
{% for branch in parallel_branches %}
workflow.add_node("{{ branch.name }}", {{ branch.name }}_node)
{%- endfor %}
workflow.add_node("aggregator", RunnableLambda(aggregator_node))

# START dispatches to all branches simultaneously via Send
workflow.add_conditional_edges(START, fan_out, [{% for branch in parallel_branches %}"{{ branch.name }}"{% if not loop.last %}, {% endif %}{% endfor %}])
{% for branch in parallel_branches %}
workflow.add_edge("{{ branch.name }}", "aggregator")
{%- endfor %}
workflow.add_edge("aggregator", END)

