#####################
## ResponsesAgent wrapper  (sync, no checkpointing)
#####################

class LangGraphResponsesAgent(ResponsesAgent):
    def __init__(self, agent):
        self.agent = agent

    def predict(self, request: ResponsesAgentRequest) -> ResponsesAgentResponse:
        outputs = [
            event.item
            for event in self.predict_stream(request)
            if event.type == "response.output_item.done"
        ]
        return ResponsesAgentResponse(output=outputs, custom_outputs=request.custom_inputs)

    def predict_stream(
        self,
        request: ResponsesAgentRequest,
    ) -> Generator[ResponsesAgentStreamEvent, None, None]:
        cc_msgs = to_chat_completions_input([i.model_dump() for i in request.input])

        max_iter = model_config.get("llm_max_iterations") or 10
        # Outer recursion limit — sized per workflow pattern:
        # - single:            max_iter tool-call rounds (max_iter * 2 + 1 graph steps)
        # - supervisor_worker: budget covers routing across all {{ worker_llms | length }} worker(s);
        #                      each worker runs its own inner ReAct loop independently
        # - sequential/parallel: outer graph is linear (limit never hit);
        #                        each inner agent was given its own limit at invocation time
{% if workflow_pattern == "single" %}
        outer_recursion_limit = max_iter * 2 + 1
{% elif workflow_pattern == "supervisor_worker" %}
        outer_recursion_limit = max_iter * {{ worker_llms | length }} * 2 + 1
{% else %}
        outer_recursion_limit = 50
{% endif %}

        first_message = True
        seen_ids: set = set()

        for _, events in self.agent.stream(
            {"messages": cc_msgs},
            stream_mode=["updates"],
            config={"recursion_limit": outer_recursion_limit},
        ):
            new_msgs = [
                msg
                for v in events.values()
                for msg in v.get("messages", [])
                if msg.id not in seen_ids
            ]
            if first_message:
                # Skip the echoed input messages on the first node update
                seen_ids.update(msg.id for msg in new_msgs[: len(cc_msgs)])
                new_msgs = new_msgs[len(cc_msgs):]
                first_message = False
            else:
                seen_ids.update(msg.id for msg in new_msgs)
{% if workflow_pattern == "supervisor_worker" %}
                # Emit the active worker name so callers can show routing steps
                node_name = next(iter(events.keys()), None)
                if node_name:
                    yield ResponsesAgentStreamEvent(
                        type="response.output_item.done",
                        item=self.create_text_output_item(
                            text=f"<name>{node_name}</name>", id=str(uuid4())
                        ),
                    )
{% endif %}
            if new_msgs:
                yield from output_to_responses_items_stream(new_msgs)
{% endif %}
