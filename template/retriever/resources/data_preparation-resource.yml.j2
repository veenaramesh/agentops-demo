{%- if retrievers %}
# Data preparation jobs: ingestion + preprocessing, one job per retriever.
# Writes raw_data_table and preprocessed_data_table. Run before vector_search jobs.
common_permissions: &permissions
  permissions:
    - level: CAN_VIEW
      group_name: users

resources:
  jobs:
{%- for retriever in retrievers %}
    data_prep_job_{{ retriever.name }}:
      parameters:
        - name: bundle_root
          default: ${workspace.file_path}
      name: ${bundle.target}-retriever-data-prep-job-{{ retriever.name }}
      tasks:
        - task_key: RawDataIngest
          notebook_task:
            notebook_path: ../data_preparation/data_ingestion/notebooks/DataIngestion.py
            base_parameters:
              uc_catalog: ${var.uc_catalog}
              schema: ${var.schema}
              raw_data_table: ${var.raw_data_table}
              data_source_url: # TODO: set your data source URL for {{ retriever.name }}
              git_source_info: url:${bundle.git.origin_url}; branch:${bundle.git.branch}; commit:${bundle.git.commit}
          environment_key: data_prep_requirements

        - task_key: PreprocessRawData
          depends_on:
            - task_key: RawDataIngest
          notebook_task:
            notebook_path: ../data_preparation/data_preprocessing/notebooks/DataPreprocessing.py
            base_parameters:
              uc_catalog: ${var.uc_catalog}
              schema: ${var.schema}
              raw_data_table: ${var.raw_data_table}
              preprocessed_data_table: ${var.preprocessed_data_table}
              max_chunk_size: 500
              min_chunk_size: 20
              chunk_overlap: 50
              hf_tokenizer_model: "openai-community/openai-gpt"
              git_source_info: url:${bundle.git.origin_url}; branch:${bundle.git.branch}; commit:${bundle.git.commit}
          environment_key: data_prep_requirements
      <<: *permissions

      environments:
        - environment_key: data_prep_requirements
          spec:
            client: "3"
            dependencies:
              - "-r /Workspace/Users/${workspace.current_user.userName}/.bundle/${bundle.name}/${bundle.target}/files/data_preparation/requirements.txt"
{%- endfor %}

targets:
  dev:
    resources:
      jobs:
{%- for retriever in retrievers %}
        data_prep_job_{{ retriever.name }}:
          schedule:
            quartz_cron_expression: "0 0 12 1 1/1 ? * "
            pause_status: "PAUSED"
            timezone_id: UTC
{%- endfor %}
  test:
    resources:
      jobs:
{%- for retriever in retrievers %}
        data_prep_job_{{ retriever.name }}:
          schedule:
            quartz_cron_expression: "0 0 12 1 1/1 ? * "
            pause_status: "PAUSED"
            timezone_id: UTC
{%- endfor %}
  prod:
    resources:
      jobs:
{%- for retriever in retrievers %}
        data_prep_job_{{ retriever.name }}:
          schedule:
            quartz_cron_expression: "0 0 12 1 1/1 ? * "
            pause_status: "UNPAUSED"
            timezone_id: UTC
{%- endfor %}
  staging:
    resources:
      jobs:
{%- for retriever in retrievers %}
        data_prep_job_{{ retriever.name }}:
          schedule:
            quartz_cron_expression: "0 0 12 1 1/1 ? * "
            pause_status: "UNPAUSED"
            timezone_id: UTC
{%- endfor %}
{%- endif %}
