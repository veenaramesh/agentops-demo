{%- set deploy_tools = tools | selectattr("deploy") | list %}
{%- if deploy_tools %}
# Databricks notebook source
# MAGIC %load_ext autoreload
# MAGIC %autoreload 2

# COMMAND ----------

# Deploys UC functions used by the agent.
# Each function is deployed to the catalog and schema defined on its canvas node.
# Run this job from the tools bundle before deploying the agent bundle.

# COMMAND ----------

import sys
dbutils.widgets.text("bundle_root", "/", "Root of bundle")
bundle_root = dbutils.widgets.get("bundle_root")
sys.path.append(bundle_root)

# COMMAND ----------

from unitycatalog.ai.core.base import set_uc_function_client
from unitycatalog.ai.core.databricks import DatabricksFunctionClient
from agent_tools import (
{%- for tool in deploy_tools %}
    {{ tool.name }},
{%- endfor %}
)

client = DatabricksFunctionClient()
set_uc_function_client(client)

# COMMAND ----------

{%- for tool in deploy_tools %}
# {{ tool.name }} → {{ tool.catalog }}.{{ tool.schema }}.{{ tool.name }}
client.create_python_function(
    func={{ tool.name }},
    catalog="{{ tool.catalog }}",
    schema="{{ tool.schema }}",
    replace=True,
)

# COMMAND ----------

{%- endfor %}

dbutils.notebook.exit(
    "UC functions deployed: "
    "{{ deploy_tools | map(attribute='name') | join(', ') }}"
)
{%- endif %}
