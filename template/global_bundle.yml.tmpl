# Shared variables across all bundles (retriever, tools, agent, evaluation).
# Included by each bundle's databricks.yml so uc_catalog and schema stay in sync.
# Target-specific schema overrides remain in each bundle's targets block.

variables:
  uc_catalog:
    description: Unity Catalog used by all bundles.
    default: {{.uc_catalog}}
  schema:
    description: UC schema (use the same value per target across all bundles).
    default: {{.project_name}}
